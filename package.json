{
  "name": "yamabiko-lite",
  "version": "0.1.4",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "description": "Lightweight inbox-driven PR remediation for AI review bots",
  "engines": {
    "bun": ">=1.3.10"
  },
  "bin": {
    "yamabiko-lite": "./bin/yamabiko-lite"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "typecheck": "sh ./scripts/bun-exec.sh x tsc --noEmit",
    "deadcode": "sh ./scripts/bun-exec.sh x knip",
    "test": "sh ./scripts/bun-exec.sh test",
    "check": "sh ./scripts/bun-exec.sh run format:check && sh ./scripts/bun-exec.sh run typecheck && sh ./scripts/bun-exec.sh run lint && sh ./scripts/bun-exec.sh run deadcode",
    "build": "sh ./scripts/bun-exec.sh build src/cli/main.ts --outdir dist --target node"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.3.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "knip": "^5.86.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "valibot": "^1.0.0"
  }
}
