{
  "name": "yamabiko-lite",
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight inbox-driven PR remediation for AI review bots",
  "bin": {
    "yamabiko-lite": "./src/cli/main.ts"
  },
  "scripts": {
    "lint": "echo 'Not configured yet'",
    "lint:fix": "echo 'Not configured yet'",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "typecheck": "bunx tsc --noEmit",
    "deadcode": "knip",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun run deadcode",
    "build": "bun build src/cli/main.ts --outdir dist --target node"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "knip": "^5.86.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "valibot": "^1.0.0"
  }
}
